{
  "project_rules": {
    "tech_stack": {
      "framework": "Next.js (App Router)",
      "language": "TypeScript",
      "styling": "Tailwind CSS",
      "database_auth": "Supabase",
      "icons": "Lucide-React"
    },
    "coding_standards": {
      "components": "Strictly use Arrow Functions for all functional components (e.g., const MyComponent = () => { ... }).",
      "state_management": "Prefer React Server Components (RSC) by default; use 'use client' only when necessary for interactivity or browser APIs.",
      "data_fetching": "Use Supabase Server Clients within Server Components for initial data loads.",
      "modularity": "Follow a 'Feature-based' folder structure (e.g., components/ui for globals, features/auth for logic-specific modules).",
      "naming_conventions": "PascalCase for components, camelCase for hooks and utilities, kebab-case for file names."
    },
    "best_practices": [
      "Use Next.js 'Image' component for all images.",
      "Use 'Link' from 'next/link' for internal navigation.",
      "Implement proper TypeScript interfaces for all Supabase table schemas.",
      "Keep components small and focused on a single responsibility.",
      "Avoid 'any' type; always define proper TypeScript interfaces or types."
    ],
    "ui_preferences": {
      "design_system": "Clean, professional, and accessible. Use Tailwind spacing scale consistently.",
      "buttons_inputs": "Prefer a consistent UI library style (like Shadcn/UI patterns) if applicable."
    }
  }
}